# ============================================================
#  FoodShield — Environment Variables Template
#  Copy this file to .env.local and fill in your real values.
#  This file is safe to commit — it contains NO real secrets.
# ============================================================

# ── GOOGLE GEMINI AI ─────────────────────────────────────────
GEMINI_API_KEY=

# ── NEXT.JS ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SUPABASE (if used) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── DATABASE (if using direct Postgres) ──────────────────────
DATABASE_URL=

# ── OPENWEATHER API (for real weather data) ──────────────────
OPENWEATHER_API_KEY=

# ── JWT / AUTH SECRETS ───────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── NODE ─────────────────────────────────────────────────────
NODE_ENV=development
