# ============================================================
#  FoodShield .gitignore
# ============================================================

# ── ENVIRONMENT / SECRETS ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── NEXT.JS ──────────────────────────────────────────────────
.next/
out/

# ── NODE ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── BUILD OUTPUTS ────────────────────────────────────────────
dist/
build/
*.tsbuildinfo
next-env.d.ts

# ── IDE / EDITOR ─────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
.DS_Store
Thumbs.db

# ── TESTING ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── LOGS ─────────────────────────────────────────────────────
logs/
*.log

# ── MISC ─────────────────────────────────────────────────────
.cache/
.turbo/
.vercel/
*.zip
*.tgz
